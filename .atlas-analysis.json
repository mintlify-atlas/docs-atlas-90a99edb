    "@arizeai/openinference-instrumentation-langchain - JS LangChain instrumentation",
    "@arizeai/openinference-semantic-conventions - JS semantic conventions",
    "OITracer - Core tracer wrapper with privacy controls",
    "TraceConfig - Privacy and masking configuration",
    "using_session() - Context manager for session tracking",
    "using_user() - Context manager for user tracking",
    "using_metadata() - Context manager for metadata",
    "using_tags() - Context manager for tags",
